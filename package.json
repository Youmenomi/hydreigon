{
  "name": "hydreigon",
  "version": "0.2.5",
  "description": "Are you looking for a Hydreigon to classify data for you? Come and catch it!",
  "keywords": [
    "typescript",
    "classify",
    "items",
    "indexer",
    "data",
    "structure",
    "management",
    "sortable",
    "pokemon",
    "hydreigon"
  ],
  "type": "module",
  "main": "./dist/hydreigon.cjs",
  "module": "./dist/hydreigon.js",
  "types": "./dist/index.d.ts",
  "unpkg": "./dist/hydreigon.global.js",
  "jsdelivr": "./dist/hydreigon.global.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/hydreigon.js",
      "require": "./dist/hydreigon.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "packageManager": "pnpm@11.6.0",
  "scripts": {
    "dev": "vitest",
    "test": "vitest run --coverage",
    "ts:check": "tsc --noEmit -p tsconfig.build.json && tsc --noEmit -p tsconfig.json",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "build:types": "tsc --emitDeclarationOnly -p tsconfig.build.json",
    "build": "pnpm run ts:check && pnpm run lint && vite build && vite build --config vite.iife.config.ts",
    "prepare": "lefthook install",
    "prepublishOnly": "pnpm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Youmenomi/hydreigon.git"
  },
  "author": "Dean Yao <youmenomi@gmail.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/Youmenomi/hydreigon/issues"
  },
  "homepage": "https://github.com/Youmenomi/hydreigon#readme",
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@microsoft/api-extractor": "^7.58.9",
    "@types/node": "^25.9.3",
    "@vitest/coverage-v8": "^4.1.8",
    "lefthook": "^2.1.9",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vite-plugin-dts": "^5.0.2",
    "vitest": "^4.1.8"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "24.16.0",
      "onFail": "download"
    }
  }
}
